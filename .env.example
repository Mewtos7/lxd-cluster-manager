# LX Container Weaver — environment variable template
# Copy this file to .env and fill in the required values.
# Never commit .env to source control.

# ── HTTP server ────────────────────────────────────────────────────────────────

# Address (host:port) the HTTP server binds to.
# Default: :8080
HTTP_ADDR=:8080

# ── Database ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required).
# Example: postgres://user:password@localhost:5432/weaver?sslmode=disable
DATABASE_URL=

# ── Authentication (ADR-003) ───────────────────────────────────────────────────

# Comma-separated list of bcrypt-hashed API keys for protected endpoints (required).
# Each client is issued a unique raw key; only the bcrypt hash is stored here.
# The server will refuse to start if this is empty.
#
# Generate a hash for a new key with:
#   make gen-api-key
# or directly with the Go tool:
#   go run ./tools/gen-api-key
#
# Example (do NOT use this hash in production):
# API_KEYS=$2a$12$examplehashvalue...

API_KEYS=

# ── Logging ────────────────────────────────────────────────────────────────────

# Minimum log level: debug | info | warn | error
# Default: info
LOG_LEVEL=info

# ── Reconciliation ─────────────────────────────────────────────────────────────

# How often the orchestration loop runs per cluster (Go duration string).
# Default: 60s
RECONCILE_INTERVAL=60s

# Maximum time to wait for in-flight requests during graceful shutdown.
# Default: 30s
SHUTDOWN_TIMEOUT=30s
