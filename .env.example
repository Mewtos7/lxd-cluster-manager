# LX Container Weaver — environment variable template
# Copy this file to .env and fill in the required values.
# Never commit .env to source control.

# ── HTTP server ────────────────────────────────────────────────────────────────

# Address (host:port) the HTTP server binds to.
# Default: :8080
HTTP_ADDR=:8080

# ── Database ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required).
# Example: postgres://user:password@localhost:5432/weaver?sslmode=disable
DATABASE_URL=

# ── Authentication (ADR-003) ───────────────────────────────────────────────────

# Comma-separated list of bcrypt-hashed API keys for protected endpoints (required).
# Each client is issued a unique raw key; only the bcrypt hash is stored here.
# The server will refuse to start if this is empty.
#
# Generate a hash for a new key with:
#   make gen-api-key
# or directly with the Go tool:
#   go run ./tools/gen-api-key
#
# Example (do NOT use this hash in production):
# API_KEYS='$2a$12$examplehashvalue...'
#
# Keep bcrypt hashes wrapped in single quotes to preserve literal '$'
# when Docker Compose reads .env.

API_KEYS=

# ── Logging ────────────────────────────────────────────────────────────────────

# Minimum log level: debug | info | warn | error
# Default: info
LOG_LEVEL=info

# ── Reconciliation ─────────────────────────────────────────────────────────────

# How often the orchestration loop runs per cluster (Go duration string).
# Default: 60s
RECONCILE_INTERVAL=60s

# Maximum time to wait for in-flight requests during graceful shutdown.
# Default: 30s
SHUTDOWN_TIMEOUT=30s

# ── Hyperscaler providers ──────────────────────────────────────────────────────

# Hetzner Cloud API token. When set, the Hetzner Cloud provider is initialised
# and wired into the orchestrator for server provisioning via Pulumi.
# Leave empty to run the manager without a cloud provider (useful for local
# development that does not require server provisioning).
HETZNER_API_TOKEN=

# ── Initial cluster bootstrap ──────────────────────────────────────────────────

# Controls whether the manager attempts to bootstrap the first LXD cluster at
# startup. When false (the default) the bootstrap path is never entered, keeping
# startup fully side-effect free and deterministic.
#
# Set to true only when no cluster exists yet and automated first-cluster
# provisioning is desired. The manager will check the cluster repository at
# startup; if at least one cluster already exists the bootstrap is skipped even
# when this flag is true.
#
# Default: false
INITIAL_BOOTSTRAP_ENABLED=false

# ── Bootstrap configuration ────────────────────────────────────────────────────
# The following three variables are only required when INITIAL_BOOTSTRAP_ENABLED=true.
# They are ignored (and not validated) when bootstrap is disabled.
# All other details (cluster name, trust token, storage config, node names and
# addresses) are auto-generated or use hardcoded defaults.

# Cloud provider to use for provisioning the initial bootstrap nodes.
# Currently supported: hetzner
BOOTSTRAP_HYPERSCALER=

# Generalized datacenter region for the bootstrap nodes (e.g. eu-central, us-east).
# Translated to the hyperscaler's native region code at provisioning time.
BOOTSTRAP_REGION=

# Abstracted server size for each bootstrap node: low | mid | high
# Translated to the hyperscaler's native instance type at provisioning time.
BOOTSTRAP_SERVER_TIER=
